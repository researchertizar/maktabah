# ════════════════════════════════════════════
#  Noble Quran Backend — Environment Config
#  Copy to .env and fill in your values
# ════════════════════════════════════════════

# ── AI Keys (all FREE tiers available) ──────
# Groq  → https://console.groq.com  (FREE, 14k tokens/min)
GROQ_API_KEY=gsk_YOUR_GROQ_KEY

# Google Gemini → https://aistudio.google.com/apikey  (FREE, 1M tokens/day)
GEMINI_API_KEY=AIza_YOUR_GEMINI_KEY

# OpenAI → https://platform.openai.com/api-keys  (PAID)
OPENAI_API_KEY=sk-YOUR_OPENAI_KEY

# ── Admin Panel ──────────────────────────────
# Minimum 12 characters
ADMIN_PASSWORD=change-this-password

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-64-byte-random-hex

# ── Server ───────────────────────────────────
PORT=3001

# Restrict in production: ALLOWED_ORIGIN=https://yourdomain.com
ALLOWED_ORIGIN=*


